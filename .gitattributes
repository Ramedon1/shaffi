# Enforce Unix line endings for all shell scripts
*.sh    text eol=lf

# Common text files
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.env   text eol=lf
*.conf  text eol=lf
*.txt   text eol=lf

# Binary files - no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
*.tar   binary
*.gz    binary
